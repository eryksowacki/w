{
  "manifest_version": 2,
  "name": "ChatGPT Moodle Helper",
  "version": "1.5.0",
  "description": "Odczytuje pytania z Moodle i kopiuje prompt do ChatGPT.",
  "permissions": [
    "tabs",
    "activeTab",
    "clipboardWrite",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "copy-current-question-prompt": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Skopiuj prompt z aktualnym pytaniem"
    },
    "open-chatgpt-with-current-question": {
      "suggested_key": {
        "default": "Alt+Shift+Q"
      },
      "description": "Otwórz ChatGPT z aktualnym pytaniem"
    },
    "copy-all-questions-prompt": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Skopiuj prompt ze wszystkimi pytaniami na stronie"
    },
    "open-chatgpt-with-all-questions": {
      "suggested_key": {
        "default": "Alt+Shift+O"
      },
      "description": "Otwórz ChatGPT ze wszystkimi pytaniami na stronie"
    }
  },
  "applications": {
    "gecko": {
      "id": "chatgpt-moodle-helper@example.local"
    }
  }
}